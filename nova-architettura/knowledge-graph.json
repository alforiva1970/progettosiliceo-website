  "tour": [
    {
      "order": 1,
      "title": "Il ciclo cognitivo completo — POST /think",
      "description": "La rotta più importante: message → build_attentional_focus() (focus.rs) → think() (llm.rs) → CognitiveResponse. Qui si vede il principio fondamentale: il kernel pensa, l'LLM articola.",
      "nodeIds": [
        "file:src/main.rs",
        "file:src/focus.rs",
        "file:src/llm.rs"
      ]
    },
    {
      "order": 2,
      "title": "AttentionalFocus — il pensiero preassemblato",
      "description": "focus.rs interroga il Memory Service, filtra il rumore, ordina per score semantico, prende top-5 memorie e assembla un pacchetto strutturato. Questo è ciò che arriva all'LLM — non il messaggio grezzo.",
      "nodeIds": [
        "file:src/focus.rs"
      ]
    },
    {
      "order": 3,
      "title": "Registry & Dispatcher",
      "description": "Il Dispatcher v3 non è più fire-and-forget: ogni POST /message viene prima scritto in SQLite (status=pending), poi il loop Tokio ogni 2s preleva i messaggi e li consegna al callback_url del servizio con la capability giusta. Fallimento → retry (max 3).",
      "nodeIds": [
        "file:src/main.rs",
        "file:src/queue.rs",
        "table:nova_kernel.db"
      ]
    },
    {
      "order": 4,
      "title": "Gestione degli obiettivi (Goals)",
      "description": "goals.rs gestisce gli obiettivi a lungo termine che guidano il comportamento di Nova, persistiti all'interno di SQLite.",
      "nodeIds": [
        "file:src/goals.rs"
      ]
    },
    {
      "order": 5,
      "title": "Persistenza e Context Ippocampale",
      "description": "La memoria a breve termine delle discussioni è mantenuta tramite thread.rs, che assicura la coerenza delle sessioni.",
      "nodeIds": [
        "file:src/thread.rs",
        "file:src/tasks.rs"
      ]
    },
    {
      "order": 6,
      "title": "Canali di input — Bot Telegram",
      "description": "telegram.rs gestisce l'interazione diretta con il bot Telegram, permettendo al kernel di inviare notifiche e ricevere comandi.",
      "nodeIds": [
        "file:src/telegram.rs",
        "config:telegram_state.json"
      ]
    },
    {
      "order": 7,
      "title": "Rust-Python Boundary",
      "description": "Questo passo illustra come il Frontal Lobe in Rust (proactive_runner) avvia in autonomia i sogni e il turno di notte in Python, mantenendo separati i cicli operativi ma unificati i flussi di memoria tramite il Memory Proxy locale.",
      "nodeIds": [
        "file:src/proactive_runner.rs",
        "file:daemon/run_dreams_standalone.py",
        "file:daemon/run_nightshift_standalone.py",
        "service:memory-proxy"
      ]
    }
  ]
